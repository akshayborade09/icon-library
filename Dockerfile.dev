# Development Dockerfile for React Icon Library

FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install dependencies for hot reloading
RUN apk add --no-cache git

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev dependencies)
RUN npm install

# Copy source code
COPY . .

# Expose port 3000
EXPOSE 3000

# Start development server
CMD ["npm", "start"] 